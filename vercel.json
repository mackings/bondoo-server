{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index?path=$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "dist/**,node_modules/tiny-secp256k1/**"
    }
  },
  "crons": [
    {
      "path": "/cron/scan-deposits",
      "schedule": "*/5 * * * *"
    }
  ]
}
